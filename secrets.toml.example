# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS :
# 1. Copie ce fichier en ".streamlit/secrets.toml" pour les tests en local
# 2. Sur Streamlit Cloud : "Manage app" → "Secrets" → colle le contenu ci-dessous
#    (sans le bloc commentaire)
# ⚠️  Ne jamais committer secrets.toml dans GitHub !
# ─────────────────────────────────────────────────────────────────────────────

# ── Choix du provider LLM ────────────────────────────────────────────────────
# "1minai"    → utilise 1min.ai  (recommandé, pas besoin de compte Anthropic)
# "anthropic" → utilise Anthropic direct
LLM_PROVIDER = "1minai"

# ── Option A : 1min.ai ───────────────────────────────────────────────────────
# Récupère ta clé sur : https://app.1min.ai/setting/api
ONEMINAI_KEY = "ta-cle-1minai-ici"

# ── Option B : Anthropic (laisser vide si tu utilises 1min.ai) ───────────────
# Récupère ta clé sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY = ""

# ── Notion ───────────────────────────────────────────────────────────────────
# Récupère ton token sur : https://www.notion.so/my-integrations
# ⚠️  Régénère-le si tu l'as accidentellement exposé dans le code !
NOTION_TOKEN = "ntn_ton-token-notion-ici"
